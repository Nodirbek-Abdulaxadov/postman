@using PostalDeliverySystem.Shared.Client.Realtime

@if (Status == RealtimeConnectionStatus.Reconnecting)
{
    <div class="alert alert-warning py-1 mb-2 d-flex align-items-center gap-2" role="alert">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        <strong>Reconnecting</strong> &mdash; live updates temporarily unavailable.
    </div>
}
else if (Status == RealtimeConnectionStatus.Disconnected)
{
    <div class="alert alert-danger py-1 mb-2" role="alert">
        <strong>Disconnected</strong> &mdash; live updates are not available.
    </div>
}
else if (IsStale)
{
    <div class="alert alert-warning py-1 mb-2" role="alert">
        <strong>No recent updates</strong> &mdash; information may be stale.
    </div>
}

@code {
    [Parameter] public RealtimeConnectionStatus Status { get; set; }
    [Parameter] public bool IsStale { get; set; }
}
